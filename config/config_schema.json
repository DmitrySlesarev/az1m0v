{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EV System Configuration Schema",
  "description": "Schema for EV system configuration file",
  "type": "object",
  "required": [
    "vehicle",
    "battery",
    "motor",
    "motor_controller",
    "charging",
    "sensors",
    "communication",
    "ui",
    "ai",
    "logging"
  ],
  "additionalProperties": true,
  "properties": {
    "vehicle": {
      "type": "object",
      "required": ["model", "serial_number", "manufacturer"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "serial_number": {"type": "string", "minLength": 1},
        "manufacturer": {"type": "string", "minLength": 1}
      }
    },
    "battery": {
      "type": "object",
      "required": ["capacity_kwh", "max_charge_rate_kw", "max_discharge_rate_kw", "nominal_voltage", "cell_count"],
      "properties": {
        "capacity_kwh": {"type": "number", "minimum": 0},
        "max_charge_rate_kw": {"type": "number", "minimum": 0},
        "max_discharge_rate_kw": {"type": "number", "minimum": 0},
        "nominal_voltage": {"type": "number", "minimum": 0},
        "cell_count": {"type": "integer", "minimum": 1},
        "min_voltage": {"type": "number", "minimum": 0},
        "max_voltage": {"type": "number", "minimum": 0},
        "min_temperature": {"type": "number"},
        "max_temperature": {"type": "number"},
        "min_soc": {"type": "number", "minimum": 0, "maximum": 100},
        "max_soc": {"type": "number", "minimum": 0, "maximum": 100},
        "balancing_enabled": {"type": "boolean"},
        "balancing_algorithm": {"type": "string", "enum": ["none", "passive", "active", "adaptive"]},
        "balancing_threshold_mv": {"type": "number", "minimum": 0},
        "passive_bleed_current_ma": {"type": "number", "minimum": 0},
        "active_balance_efficiency": {"type": "number", "minimum": 0, "maximum": 1},
        "balancing_min_soc": {"type": "number", "minimum": 0, "maximum": 100},
        "balancing_max_soc": {"type": "number", "minimum": 0, "maximum": 100},
        "adaptive_active_balance_threshold_mv": {"type": "number", "minimum": 0},
        "active_balance_transfer_rate_per_s": {"type": "number", "minimum": 0},
        "active_balance_transfer_cap_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "status_critical_soc_low": {"type": "number", "minimum": 0, "maximum": 100},
        "status_critical_soc_high": {"type": "number", "minimum": 0, "maximum": 100},
        "status_warning_soc_low": {"type": "number", "minimum": 0, "maximum": 100},
        "status_warning_soc_high": {"type": "number", "minimum": 0, "maximum": 100},
        "status_voltage_imbalance_fault_v": {"type": "number", "minimum": 0},
        "status_uniform_temperature_spread_c": {"type": "number", "minimum": 0},
        "status_charge_current_threshold_a": {"type": "number", "minimum": 0},
        "status_warning_temp_high_ratio": {"type": "number", "minimum": 0},
        "status_warning_temp_low_ratio": {"type": "number", "minimum": 0},
        "charge_cycle_soc_low_threshold": {"type": "number", "minimum": 0, "maximum": 100},
        "charge_cycle_soc_high_threshold": {"type": "number", "minimum": 0, "maximum": 100},
        "charge_cycle_partial_energy_ratio": {"type": "number", "minimum": 0},
        "charge_cycle_full_energy_ratio": {"type": "number", "minimum": 0},
        "soh_temperature_history_days": {"type": "number", "minimum": 0},
        "soh_high_temperature_threshold_c": {"type": "number"},
        "soh_cycle_degradation_per_cycle_pct": {"type": "number", "minimum": 0},
        "soh_high_temp_degradation_per_hour_pct": {"type": "number", "minimum": 0},
        "soh_fault_degradation_per_fault_pct": {"type": "number", "minimum": 0},
        "soh_calendar_degradation_per_year_pct": {"type": "number", "minimum": 0},
        "soh_calendar_temperature_reference_c": {"type": "number"},
        "soh_calendar_temp_factor_per_10c": {"type": "number", "minimum": 0}
      }
    },
    "motor": {
      "type": "object",
      "required": ["max_power_kw", "max_torque_nm", "efficiency", "type"],
      "properties": {
        "max_power_kw": {"type": "number", "minimum": 0},
        "max_torque_nm": {"type": "number", "minimum": 0},
        "efficiency": {"type": "number", "minimum": 0, "maximum": 1},
        "type": {"type": "string", "enum": ["permanent_magnet", "induction", "switched_reluctance"]}
      }
    },
    "motor_controller": {
      "type": "object",
      "required": ["type", "serial_port", "can_enabled"],
      "properties": {
        "type": {"type": "string", "enum": ["vesc", "other"]},
        "serial_port": {"type": "string", "minLength": 1},
        "can_enabled": {"type": "boolean"},
        "max_current_a": {"type": "number", "minimum": 0},
        "max_rpm": {"type": "number", "minimum": 0},
        "max_temperature_c": {"type": "number", "minimum": 0},
        "min_voltage_v": {"type": "number", "minimum": 0},
        "max_voltage_v": {"type": "number", "minimum": 0},
        "update_interval_ms": {"type": "integer", "minimum": 1}
      }
    },
    "charging": {
      "type": "object",
      "required": ["ac_max_power_kw", "dc_max_power_kw", "connector_type", "fast_charge_enabled"],
      "properties": {
        "ac_max_power_kw": {"type": "number", "minimum": 0},
        "dc_max_power_kw": {"type": "number", "minimum": 0},
        "connector_type": {"type": "string", "enum": ["CCS1", "CCS2", "CHAdeMO", "Tesla"]},
        "fast_charge_enabled": {"type": "boolean"},
        "max_temperature_c": {"type": "number", "minimum": 0},
        "max_voltage_v": {"type": "number", "minimum": 0},
        "min_voltage_v": {"type": "number", "minimum": 0}
      }
    },
    "sensors": {
      "type": "object",
      "required": ["imu_enabled", "gps_enabled", "temperature_sensors", "sampling_rate_hz"],
      "properties": {
        "imu_enabled": {"type": "boolean"},
        "gps_enabled": {"type": "boolean"},
        "temperature_sensors": {"type": "integer", "minimum": 0},
        "sampling_rate_hz": {"type": "number", "minimum": 0}
      }
    },
    "imu": {
      "type": "object",
      "required": ["sensor_type", "i2c_address", "i2c_bus", "sampling_rate_hz", "simulation_mode"],
      "properties": {
        "sensor_type": {"type": "string", "enum": ["mpu6050", "mpu9250"]},
        "i2c_address": {"type": "integer", "minimum": 0, "maximum": 255},
        "i2c_bus": {"type": "integer", "minimum": 0},
        "sampling_rate_hz": {"type": "number", "minimum": 1, "maximum": 1000},
        "simulation_mode": {"type": "boolean"},
        "calibration_samples": {"type": "integer", "minimum": 10, "maximum": 1000},
        "accel_offset_x": {"type": "number"},
        "accel_offset_y": {"type": "number"},
        "accel_offset_z": {"type": "number"},
        "gyro_offset_x": {"type": "number"},
        "gyro_offset_y": {"type": "number"},
        "gyro_offset_z": {"type": "number"},
        "mag_offset_x": {"type": "number"},
        "mag_offset_y": {"type": "number"},
        "mag_offset_z": {"type": "number"}
      }
    },
    "temperature_sensors": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "cells_per_group": {"type": "integer", "minimum": 1},
        "update_interval_s": {"type": "number", "minimum": 0.01},
        "coolant_enabled": {"type": "boolean"},
        "motor_stator_enabled": {"type": "boolean"},
        "motor_stator_sensors": {"type": "integer", "minimum": 1},
        "charging_enabled": {"type": "boolean"},
        "battery_cell_group": {
          "type": "object",
          "properties": {
            "min_temperature": {"type": "number"},
            "max_temperature": {"type": "number"},
            "warning_threshold_low": {"type": "number"},
            "warning_threshold_high": {"type": "number"},
            "fault_threshold_low": {"type": "number"},
            "fault_threshold_high": {"type": "number"}
          }
        },
        "coolant": {
          "type": "object",
          "properties": {
            "min_temperature": {"type": "number"},
            "max_temperature": {"type": "number"},
            "warning_threshold_low": {"type": "number"},
            "warning_threshold_high": {"type": "number"},
            "fault_threshold_low": {"type": "number"},
            "fault_threshold_high": {"type": "number"}
          }
        },
        "motor_stator": {
          "type": "object",
          "properties": {
            "min_temperature": {"type": "number"},
            "max_temperature": {"type": "number"},
            "warning_threshold_low": {"type": "number"},
            "warning_threshold_high": {"type": "number"},
            "fault_threshold_low": {"type": "number"},
            "fault_threshold_high": {"type": "number"}
          }
        },
        "charging": {
          "type": "object",
          "properties": {
            "min_temperature": {"type": "number"},
            "max_temperature": {"type": "number"},
            "warning_threshold_low": {"type": "number"},
            "warning_threshold_high": {"type": "number"},
            "fault_threshold_low": {"type": "number"},
            "fault_threshold_high": {"type": "number"}
          }
        }
      }
    },
    "gps": {
      "type": "object",
      "properties": {
        "serial_port": {"type": ["string", "null"]},
        "baudrate": {"type": "integer", "minimum": 1200},
        "update_interval_s": {"type": "number", "minimum": 0.1},
        "simulation_mode": {"type": "boolean"},
        "simulation_base_latitude": {"type": "number", "minimum": -90, "maximum": 90},
        "simulation_base_longitude": {"type": "number", "minimum": -180, "maximum": 180},
        "simulation_radius_deg": {"type": "number", "minimum": 0},
        "simulation_angle_rate": {"type": "number"},
        "simulation_speed_base_kmh": {"type": "number", "minimum": 0},
        "simulation_speed_amplitude_kmh": {"type": "number", "minimum": 0},
        "simulation_altitude_m": {"type": "number"},
        "simulation_satellites": {"type": "integer", "minimum": 0},
        "simulation_hdop": {"type": "number", "minimum": 0}
      }
    },
    "communication": {
      "type": "object",
      "required": ["can_bus_enabled", "update_interval_ms"],
      "properties": {
        "can_bus_enabled": {"type": "boolean"},
        "update_interval_ms": {"type": "integer", "minimum": 1}
      }
    },
    "can_bus": {
      "type": "object",
      "required": ["channel", "bitrate", "interface"],
      "properties": {
        "channel": {"type": "string", "minLength": 1},
        "bitrate": {"type": "integer", "minimum": 125000, "maximum": 1000000},
        "interface": {"type": "string", "enum": ["socketcan", "virtual", "slcan"]}
      }
    },
    "vehicle_controller": {
      "type": "object",
      "required": ["max_speed_kmh", "max_acceleration_ms2", "max_deceleration_ms2", "max_power_kw", "efficiency_wh_per_km", "weight_kg"],
      "properties": {
        "max_speed_kmh": {"type": "number", "minimum": 0},
        "max_acceleration_ms2": {"type": "number", "minimum": 0},
        "max_deceleration_ms2": {"type": "number", "maximum": 0},
        "max_power_kw": {"type": "number", "minimum": 0},
        "efficiency_wh_per_km": {"type": "number", "minimum": 0},
        "weight_kg": {"type": "number", "minimum": 0},
        "drive_mode_multiplier_eco": {"type": "number", "minimum": 0},
        "drive_mode_multiplier_normal": {"type": "number", "minimum": 0},
        "drive_mode_multiplier_sport": {"type": "number", "minimum": 0},
        "drive_mode_multiplier_reverse": {"type": "number", "minimum": 0},
        "min_soc_to_drive": {"type": "number", "minimum": 0, "maximum": 100},
        "regen_max_current_a": {"type": "number", "minimum": 0},
        "rpm_to_speed_factor_kmh": {"type": "number", "minimum": 0},
        "speed_zero_threshold_kmh": {"type": "number", "minimum": 0}
      }
    },
    "telemetry": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "server_url": {"type": "string"},
        "server_port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "api_key": {"type": "string"},
        "update_interval_s": {"type": "number", "minimum": 0.1},
        "connection_timeout_s": {"type": "number", "minimum": 1},
        "retry_attempts": {"type": "integer", "minimum": 0},
        "retry_delay_s": {"type": "number", "minimum": 0},
        "use_ssl": {"type": "boolean"},
        "cellular_apn": {"type": "string"},
        "cellular_username": {"type": "string"},
        "cellular_password": {"type": "string"},
        "simulation_mode": {"type": "boolean"}
      }
    },
    "ui": {
      "type": "object",
      "required": ["dashboard_enabled", "mobile_app_enabled", "theme"],
      "properties": {
        "dashboard_enabled": {"type": "boolean"},
        "mobile_app_enabled": {"type": "boolean"},
        "theme": {"type": "string", "enum": ["light", "dark", "auto"]},
        "dashboard_host": {"type": "string"},
        "dashboard_port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "dashboard_debug": {"type": "boolean"},
        "dashboard_secret_key": {"type": "string", "minLength": 1},
        "dashboard_update_interval_s": {"type": "number", "minimum": 0.01},
        "dashboard_socketio_cors": {"type": "string"}
      }
    },
    "ai": {
      "type": "object",
      "required": ["autopilot_enabled", "computer_vision_enabled", "model_path"],
      "properties": {
        "autopilot_enabled": {"type": "boolean"},
        "computer_vision_enabled": {"type": "boolean"},
        "model_path": {"type": "string", "minLength": 1},
        "min_following_distance": {"type": "number", "minimum": 0},
        "max_speed": {"type": "number", "minimum": 0},
        "emergency_brake_threshold": {"type": "number", "minimum": 0},
        "autopilot_activation_max_speed": {"type": "number", "minimum": 0},
        "assist_target_speed": {"type": "number", "minimum": 0},
        "speed_control_deadband": {"type": "number", "minimum": 0},
        "speed_control_throttle_gain": {"type": "number", "minimum": 0},
        "speed_control_brake_gain": {"type": "number", "minimum": 0},
        "speed_control_hold_throttle": {"type": "number", "minimum": 0},
        "lane_steering_gain": {"type": "number", "minimum": 0},
        "adaptive_cruise_follow_distance_multiplier": {"type": "number", "minimum": 0},
        "adaptive_cruise_vehicle_classes": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      }
    },
    "safety_system": {
      "type": "object",
      "properties": {
        "battery_temp_max": {"type": "number"},
        "battery_temp_warning": {"type": "number"},
        "motor_temp_max": {"type": "number"},
        "motor_temp_warning": {"type": "number"},
        "thermal_runaway_rate": {"type": "number", "minimum": 0},
        "thermal_runaway_threshold": {"type": "number", "minimum": 0},
        "thermal_history_max_samples": {"type": "integer", "minimum": 10},
        "thermal_runaway_window_samples": {"type": "integer", "minimum": 2},
        "voltage_max": {"type": "number"},
        "voltage_min": {"type": "number"},
        "current_max": {"type": "number", "minimum": 0},
        "max_fault_history": {"type": "integer", "minimum": 1},
        "diagnostics_log_dir": {"type": ["string", "null"]}
      }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "dtc_max_history_size": {"type": "integer", "minimum": 1},
        "dtc_export_history_limit": {"type": "integer", "minimum": 1},
        "mode_history_limit": {"type": "integer", "minimum": 1},
        "fault_log_max_file_size_mb": {"type": "number", "minimum": 0.1},
        "fault_json_max_entries": {"type": "integer", "minimum": 1},
        "limp_home_profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "max_speed_kmh": {"type": "number", "minimum": 0},
              "max_power_kw": {"type": "number", "minimum": 0},
              "max_acceleration_ms2": {"type": "number", "minimum": 0},
              "max_current_a": {"type": "number", "minimum": 0},
              "charging_allowed": {"type": "boolean"},
              "autopilot_allowed": {"type": "boolean"}
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "main_loop_interval_s": {"type": "number", "minimum": 0.01},
        "dashboard_thread_join_timeout_s": {"type": "number", "minimum": 0.0},
        "default_temperature_c": {"type": "number"}
      }
    },
    "logging": {
      "type": "object",
      "required": ["level", "file_path", "max_file_size_mb", "backup_count"],
      "properties": {
        "level": {"type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]},
        "file_path": {"type": "string", "minLength": 1},
        "max_file_size_mb": {"type": "integer", "minimum": 1},
        "backup_count": {"type": "integer", "minimum": 0}
      }
    }
  }
}
